rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidSphere(data) {
      return data.keys().hasAll(['emotion', 'color', 'x', 'y', 'z', 'vx', 'vy', 'vz', 'size', 'userId', 'createdAt']) &&
             data.keys().size() == 11 &&
             data.emotion is string && data.emotion.size() <= 50 &&
             data.color is string && data.color.matches('^#[A-Fa-f0-9]{6}$') &&
             data.x is number && data.y is number && data.z is number &&
             data.vx is number && data.vy is number && data.vz is number &&
             data.size is number && data.size >= 0.1 && data.size <= 2.0 &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    match /spheres/{sphereId} {
      allow read: if true; // Publicly viewable
      allow create: if isSignedIn() && isValidSphere(request.resource.data);
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
